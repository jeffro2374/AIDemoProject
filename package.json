{
  "name": "hotel-reservation-app",
  "version": "1.0.0",
  "description": "Simple hotel reservation app for test mapping demo",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "test": "npx bddgen && playwright test",
    "test:headed": "npx bddgen && playwright test --headed",
    "bddgen": "npx bddgen",
    "map:generate": "node tools/collect-coverage.js",
    "map:summary": "node tools/query-map.js summary",
    "map:untested": "node tools/query-map.js untested",
    "map:coverage": "node tools/query-map.js coverage",
    "map:changes": "node tools/query-map.js changes",
    "test:affected": "node tools/query-map.js run-affected"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@playwright/test": "^1.40.0",
    "c8": "^11.0.0",
    "playwright-bdd": "^8.4.2"
  }
}
